# Supabase Config (frontend + worker)
VITE_SUPABASE_URL=https://csqlnblhkwpvmxoscvld.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Config (worker/backend only — use service key for DB writes)
SUPABASE_URL=https://csqlnblhkwpvmxoscvld.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Sender identity
FROM_EMAIL=noreply@yourcompany.com
FROM_NAME=MailRax

# Worker Backend URL (used by frontend to call the worker HTTP server)
VITE_WORKER_URL=https://your-worker-url.com

# Worker tuning (optional)
POLL_INTERVAL=10000
BATCH_SIZE=100
DELAY_BETWEEN_BATCHES=2000
